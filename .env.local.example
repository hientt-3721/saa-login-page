# Environment variables — copy to .env.local and fill in values
# NEVER commit .env.local to version control

# Supabase project URL (from Supabase dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google Workspace domain allowed to log in (e.g. sun-asterisk.com)
# Fail-closed: login is rejected if this variable is unset
ALLOWED_EMAIL_DOMAIN=sun-asterisk.com

# App base URL (used to construct OAuth redirectTo)
NEXT_PUBLIC_APP_URL=http://localhost:3000
